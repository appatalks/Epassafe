<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:orientation="vertical"
                      android:gravity="center_vertical|center_horizontal"
                      android:paddingLeft="5dp"
                      android:paddingRight="5dp">

            <TextView android:id="@+id/master_password_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/request_master_password"
                    android:layout_marginBottom="20dp"/>

            <EditText android:id="@+id/password" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:importantForAccessibility="no"
                    android:layout_marginBottom="20dp"
                    android:hint="@string/password"/>

   			<ImageView
   			    android:id="@+id/imagefield"
   			    android:layout_width="110dp"
   			    android:layout_height="110dp"
   			    android:src="@drawable/logo" >
			</ImageView>

            <!-- YubiKey NFC status (visible only when enrolled) -->
            <LinearLayout
                android:id="@+id/yubikey_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/yubikey_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/yubikey_tap_to_unlock"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:drawablePadding="8dp"
                    android:gravity="center" />

                <ProgressBar
                    android:id="@+id/yubikey_progress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/yubikey_result"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/yubikey_lost_key"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/yubikey_lost_key_link"
                    android:textSize="13sp"
                    android:textColor="#FF9800"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView> 

    <LinearLayout
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        style="@android:style/ButtonBar">

        <Button android:id="@+id/master_password_open_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/open_label"
            style="@android:style/Widget.Button"
            android:width="100dp"/>

    </LinearLayout>

</LinearLayout>
